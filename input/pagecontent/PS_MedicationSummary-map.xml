                    </tr>
                    <tr>
                        <td>medication.doseForm</td>
                        <td>A.2.5.1.6 - Pharmaceutical dose form</td>
                        <td>equivalent</td>
                        <td>(Medication.cz-medication-ps)</td>
                        <td>Medication.form</td>
                        <td></td>
                    </tr>
                </tbody>
